{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "google/gemma-4-26b-a4b"
        },
        "gemma-4-e4b-it": {
          "name": "gemma-4-e4b-it"
        }
      }
    }
  },
  "formatter": false,
  "default_agent": "dumbass",
  "model": "deepseek/deepseek-v4-flash",
  "small_model": "deepseek/deepseek-v4-flash",
  "mode": {
    "dumbass": {
      "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": {
          "cd *": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "find *": "allow",
          "*": "ask",
          "git *": "ask",
          "git status *": "ask",
          "git commit *": "deny",
          "git push *": "deny"
        },
        "webfetch": "ask",
        "doom_loop": "ask",
        "external_directory": {
          "/tmp/**": "allow",
          "*": "ask"
        }
      }
    },
  },
  "lsp": {
    "kotlin-ls": {
      "disabled": true
    },
    "rust": {
      "command": [
        "/home/uneeb/.cargo/bin/lspmux"
      ],
      "extensions": [
        ".rs"
      ]
    }
  },
  "mcp": {
    "kindly-web-search": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/Shelpuk-AI-Technology-Consulting/kindly-web-search-mcp-server",
        "kindly-web-search-mcp-server",
        "start-mcp-server"
      ],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "KINDLY_TOOL_TOTAL_TIMEOUT_SECONDS": "180",
        "KINDLY_WEB_SEARCH_MAX_CONCURRENCY": "3",
        "KINDLY_DIAGNOSTICS": "1"
      },
      "enabled": true
    },
    "grepai": {
      "type": "local",
      "enabled": true,
      "command": [
        "grepai",
        "mcp-serve"
      ]
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "cc-safety-net",
    "opencode-handoff",
  ],
}
