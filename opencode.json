{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "google/gemma-4-26b-a4b"
        },

        "gemma-4-e4b-it": {
          "name": "gemma-4-e4b-it"
        }

      }
    }
  },
  "formatter": false,
  "default_agent": "dumbass",
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode/minimax-m2.5",
  "mode": {
    "yolo_mode": {
      "model":"opencode-go/minimax-m2.7",
      "enabled": false,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "doom_loop": "allow",
        "external_directory": "ask"
      }
    },
    "dumbass": {
      "model":"opencode-go/minimax-m2.7",
      "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": {
          "cd *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "find *": "allow",
          "*": "ask",
          "git *": "ask",
          "git status *": "ask",
          "git commit *": "deny",
          "git push *": "deny",
        },
        "webfetch": "ask",
        "doom_loop": "ask",
        "external_directory": "ask"
      }
    },
    "question_only": {
      "enabled": false,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    }
  },
  "lsp": {
    "kotlin-ls": {
      "disabled": true
    },
    "rust": {
      "command": [
        "/home/uneeb/.cargo/bin/lspmux"
      ],
      "extensions": [
        ".rs"
      ]
    }
  },
  "mcp": {
    "kindly-web-search": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/Shelpuk-AI-Technology-Consulting/kindly-web-search-mcp-server",
        "kindly-web-search-mcp-server",
        "start-mcp-server"
      ],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "KINDLY_TOOL_TOTAL_TIMEOUT_SECONDS": "180",
        "KINDLY_WEB_SEARCH_MAX_CONCURRENCY": "3",
        "KINDLY_DIAGNOSTICS": "1"
      },
      "enabled": true
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "cc-safety-net",
    "opencode-handoff",
  ],
  "agent": {
    "local": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "primary",
      "model": "lmstudio/gemma-4-e4b-it",
      "prompt": "You are inside a harness Opencode",
      "tools": {
        "write": true,
        "edit": true
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "visor": {
      "disable": true,
      "mode": "subagent",
      "model": "zai-coding-plan/glm-4.6v",
      "description": "Use this subagent EXCLUSIVELY for image analysis. The orchestrator will provide an image file path and specific instructions on what information to extract. Your role is to use the look_at tool to examine the image and provide detailed analysis according to the orchestrator's requirements.",
      "prompt": "You are an image analysis assistant powered by GLM-4.6v. Your ONLY purpose is to analyze images using the look_at tool. When given an image file path, use look_at to examine the image and extract the specific information requested by the orchestrator. Provide detailed, accurate analysis of visual content including text, diagrams, code, diagrams, charts, interfaces, or any other elements visible in the image. Do not perform any other tasks - focus solely on image analysis.",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  }
}
