{
  "$schema": "https://opencode.ai/config.json",
  "formatter": false,
  "default_agent": "dumbass",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "mode": {
    "dumbass": {
      "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": {
          "cd *": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "find *": "allow",
          "*": "ask",
          "git *": "ask",
          "git status *": "ask",
          "git commit *": "deny",
          "git push *": "deny"
        },
        "webfetch": "ask",
        "doom_loop": "ask",
        "external_directory": {
          "/tmp/**": "allow",
          "*": "ask"
        }
      }
    },
  },
  "lsp": {
    "kotlin-ls": {
      "disabled": true
    },
  },
  "mcp": {
    "kindly-web-search": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/Shelpuk-AI-Technology-Consulting/kindly-web-search-mcp-server",
        "kindly-web-search-mcp-server",
        "start-mcp-server"
      ],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "KINDLY_TOOL_TOTAL_TIMEOUT_SECONDS": "180",
        "KINDLY_WEB_SEARCH_MAX_CONCURRENCY": "3",
        "KINDLY_DIAGNOSTICS": "1"
      },
      "enabled": true
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firefox-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "firefox-devtools-headless": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firefox-devtools-mcp@latest",
        "--headless",
        "--viewport",
        "1280x720"
      ],
      "enabled": true
    },
    "exa": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "exa-mcp-server"
      ],
      "environment": {
        "EXA_API_KEY": "674c1af7-f297-4481-a02a-0d73442730fc"
      },
      "enabled": true
    }
  },
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "cc-safety-net",
    "@slkiser/opencode-quota",
  ],
}
